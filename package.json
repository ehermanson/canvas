{
  "name": "canvas-tools-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:hang-time": "vp run --filter @canvas-tools/hang-time dev",
    "dev:floor-plan": "vp run --filter @canvas-tools/floor-plan dev",
    "deploy:hang-time": "vp run --filter @canvas-tools/hang-time deploy",
    "deploy:floor-plan": "vp run --filter @canvas-tools/floor-plan deploy",
    "deploy:dry-run:hang-time": "vp run --filter @canvas-tools/hang-time deploy:dry-run",
    "deploy:dry-run:floor-plan": "vp run --filter @canvas-tools/floor-plan deploy:dry-run",
    "build:hang-time": "vp run --filter @canvas-tools/hang-time build",
    "build:floor-plan": "vp run --filter @canvas-tools/floor-plan build",
    "test:hang-time": "vp run --filter @canvas-tools/hang-time test",
    "test:floor-plan": "vp run --filter @canvas-tools/floor-plan test",
    "test:viewport": "vp run --filter @canvas-tools/viewport test",
    "lint": "vp check",
    "build": "vp run -r build",
    "test": "vp run -r test",
    "ci": "vp check && vp run -r test && vp run -r build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@matthamlin/dodo": "0.1.0"
  },
  "devDependencies": {
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "npm@11.11.1"
}

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "floor-plan",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-08",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },

  "observability": {
    "enabled": true
  },

  "routes": [{ "pattern": "floor-plan.app", "custom_domain": true }]
}
